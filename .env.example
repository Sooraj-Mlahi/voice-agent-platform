# ── Retell AI ────────────────────────────────────────────────────────────────
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenRouter ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWT_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Redis ─────────────────────────────────────────────────────────────────────
# Railway: copy the Redis service REDIS_URL from the Variables tab.
# Local dev: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Webhook ───────────────────────────────────────────────────────────────────
# Public base URL — appended with /webhook/retell for Retell callbacks.
# Railway: https://<your-service>.up.railway.app
WEBHOOK_BASE_URL=https://<your-service>.up.railway.app

# ── VAD / Barge-in tuning (override without code deploy) ─────────────────────
INTERRUPTION_SENSITIVITY=0.9
BACKCHANNEL_FREQUENCY=0.45

# ── Silence handling ──────────────────────────────────────────────────────────
SILENCE_TIMEOUT_SECONDS=10
MAX_SILENCE_PROMPTS=2

# ── Development only — NEVER true in production ───────────────────────────────
DEV_MODE=false
